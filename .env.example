# ── Frugal AI Agent Swarm — Environment Variables ────────────────────────────
# Copy this file to .env and edit as needed.
# docker compose automatically loads .env from the project root.

# Ollama runs locally on your machine (not in Docker).
# Use localhost when running the dashboard directly (make run):
OLLAMA_BASE_URL=http://localhost:11434

# When running the dashboard in Docker (make up-d), uncomment this instead:
# OLLAMA_BASE_URL=http://host.docker.internal:11434

OLLAMA_TIMEOUT=120

# Set to 1 to enable low-watermark hardware mode (reduced N, tokens, rounds)
LOW_WATERMARK_MODE=0

# RBAC role for this process (researcher | educator | admin | readonly)
SWARM_ROLE=researcher

# MLflow tracking (leave blank to use default DATA_DIR/mlflow)
# MLFLOW_TRACKING_URI=http://mlflow-server:5000
